pipeline {
    agent any

    stages {

        stage('pull') {
            steps {
               git branch: 'main', url: 'https://github.com/omverma001/Easycrud-student-registration.git'
            }
        }

        stage('build') {
            steps {
                sh '''cd backend
                  mvn package -DskipTests'''
            }
        }

        stage('test') {
            steps {
                withSonarQubeEnv(installationName:'sonarqube' , credentialsId: 'sonar-ID') {
             sh '''cd backend
              mvn sonar:sonar  -Dsonar.projectKey=studentapp2'''
              }
            }
        }
        stage('QUALITY-GATE'){
           steps{
               timeout(10) {
            waitForQualityGate abortPipeline: true, credentialsId: 'sonar-ID'
           }
           }  
        }
        stage('delivery') {
            steps {
                sh 'aws s3 cp backend/target/student-registration-backend-0.0.1-SNAPSHOT.jar   s3://auto-student-erp/student.erp'
            }
        }

    }
}
